generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EnrollmentStatus {
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  WAIVED
}

enum CourseResourceType {
  LINK
  FILE
}

model Course {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  summary     String
  description String
  modality    String
  priceCents  Int
  priceLabel  String
  seats       Int?
  startDate   DateTime
  endDate     DateTime?
  duration    String
  location    String
  instructor  String
  level       CourseLevel    @default(BEGINNER)
  category    String         @default("Tecnología")
  status      CourseStatus   @default(PUBLISHED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  modules     Module[]
  enrollments Enrollment[]
  resources   CourseResource[]
}

model Module {
  id              String     @id @default(cuid())
  courseId        String
  title           String
  description     String
  order           Int
  durationMinutes Int?
  required        Boolean    @default(true)
  content         String?    @default("")  // Markdown or HTML lesson content
  quizData        Json?      // Array of questions [ { question: string, options: string[], answerIndex: number } ]
  course          Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress        Progress[]

  @@unique([courseId, order])
}

model Participant {
  id                    String       @id @default(cuid())
  fullName              String
  email                 String?      @unique
  phone                 String       @default("")
  cedula                String?      @unique
  loginIdentifier       String?      @unique  // normalized cedula or phone used for login
  city                  String?
  organization          String?
  visualProfile         String?
  notes                 String?
  passwordHash          String?
  mustSetPassword       Boolean      @default(true)   // first-time setup required
  passwordSetAt         DateTime?
  emailVerified         Boolean      @default(false)
  verificationToken     String?
  verificationExpiresAt DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  enrollments           Enrollment[]
  certificates          Certificate[]
}

model Enrollment {
  id               String           @id @default(cuid())
  referenceCode    String           @unique
  courseId         String
  participantId    String
  status           EnrollmentStatus @default(PENDING_PAYMENT)
  paymentStatus    PaymentStatus    @default(PENDING)
  attendancePercent Int             @default(0)
  progressPercent  Int              @default(0)
  zoomConfirmed    Boolean          @default(false)
  enrolledByAdmin  Boolean          @default(false)
  completedAt      DateTime?
  enrolledAt       DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  participant      Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  progress         Progress[]
  certificate      Certificate?

  @@unique([courseId, participantId])
}

model Progress {
  id           String      @id @default(cuid())
  enrollmentId String
  moduleId     String
  completed    Boolean     @default(false)
  completedAt  DateTime?
  quizScore    Int?        @default(0)
  isPassed     Boolean     @default(false)
  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module       Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, moduleId])
}

model Certificate {
  id              String      @id @default(cuid())
  certificateCode String      @unique
  enrollmentId    String      @unique
  participantId   String
  issuedAt        DateTime    @default(now())
  valid           Boolean     @default(true)
  verificationUrl String
  enrollment      Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CourseResource {
  id          String             @id @default(cuid())
  courseId    String
  title       String
  description String?
  type        CourseResourceType
  url         String?
  filePath    String?
  mimeType    String?
  sizeBytes   Int?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
}
